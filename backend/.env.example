##############################################################################
# WaKasir — Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# NEVER commit your actual .env file to version control.
##############################################################################

# ── App Core ─────────────────────────────────────────────────────────────────
APP_NAME=WaKasir
APP_ENV=local                    # local | staging | production
APP_KEY=                         # Run: php artisan key:generate
APP_DEBUG=true                   # Set false in production
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug                  # Set 'warning' or 'error' in production

# ── Database ──────────────────────────────────────────────────────────────────
# Development: SQLite (zero setup)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# Production: MySQL / PostgreSQL (uncomment and fill)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=wakasir
# DB_USERNAME=wakasir_user
# DB_PASSWORD=your_strong_password_here

# ── Cache / Queue / Session ───────────────────────────────────────────────────
# Production: use Redis for all three
CACHE_STORE=database             # redis in production
SESSION_DRIVER=database          # redis in production
QUEUE_CONNECTION=database        # redis in production (with Horizon)

SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# ── Sanctum Token Expiration ─────────────────────────────────────────────────
# Minutes until token expires. null = never (dev only). Set 10080 (7 days) for prod.
SANCTUM_TOKEN_EXPIRATION=null

# ── Mail ──────────────────────────────────────────────────────────────────────
# URL of the Angular frontend (no trailing slash)
FRONTEND_URL=http://localhost:4200
# FRONTEND_URL_EXTRA=https://staging.app.wakasir.com   # optional second origin

# ── Midtrans (GLOBAL FALLBACK — not used in production per-business flow) ─────
# In production each business uses their own keys stored encrypted in DB.
# These globals are used only for local dev / testing without a real business.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false     # Set true only for live payments

# ── RajaOngkir (GLOBAL FALLBACK — same note as Midtrans above) ───────────────
RAJAONGKIR_API_KEY=
RAJAONGKIR_BASE_URL=https://api.rajaongkir.com/starter

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Global fallback token (dev only). In production, each business has their own
# token stored encrypted in the businesses.wa_access_token column.
WA_ACCESS_TOKEN=

# WhatsApp Business phone number ID (for webhook routing)
WA_PHONE_ID=

# Your single WhatsApp app webhook verify token (you choose this string).
# Must match exactly what you set in the Meta App webhook configuration.
WA_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here

WA_BASE_URL=https://graph.facebook.com/v18.0

# ── Meta / Facebook — BSP Embedded Signup ────────────────────────────────────
# These belong to YOUR WaKasir Meta App (not to individual clients).
# Get them from: https://developers.facebook.com → Your App → Settings → Basic

META_APP_ID=                     # Numeric App ID
META_APP_SECRET=                 # App Secret (keep secret!)

# Configuration ID for Embedded Signup flow.
# Get it from: Meta App → WhatsApp → Configuration → Embedded Signup
META_EMBEDDED_SIGNUP_CONFIG_ID=

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# Production: use S3 or compatible (for product images via MediaLibrary)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=wakasir-media
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log                  # Use 'smtp' or 'ses' in production
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@wakasir.com"
MAIL_FROM_NAME="WaKasir"

# ── Seeder ────────────────────────────────────────────────────────────────────
# Credentials used by DatabaseSeeder for the demo owner account (local dev only)
SEED_OWNER_EMAIL=admin@wakasir.dev
SEED_OWNER_PASSWORD=password     # Change this to something strong
SEED_OWNER_NAME="Admin Demo"
